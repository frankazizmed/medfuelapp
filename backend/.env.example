# Clinical Evidence island — all env vars are CE_-prefixed.
CE_OPENAI_API_KEY=
CE_ANTHROPIC_API_KEY=
CE_TAVILY_API_KEY=
CE_FIRECRAWL_API_KEY=
CE_NCBI_API_KEY=
CE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/medfuel
CE_SEC_USER_AGENT="MedFuel Clinical Evidence Engine ops@medfuel.example"

CE_EXTRACTION_MODEL=gpt-5.5-mini
CE_NARRATIVE_MODEL=claude-opus-4-7
CE_NARRATIVE_FALLBACK_MODEL=claude-sonnet-4-6
CE_EMBEDDING_MODEL=text-embedding-3-large
CE_EMBEDDING_DIM=3072

CE_DEFAULT_PAGE_TARGET=6
CE_MAX_PAGE_TARGET=10
CE_EXPANSION_THRESHOLD=0.10

CE_REQUEST_TIMEOUT_S=30
CE_MAX_CONCURRENT_FETCHES=8
