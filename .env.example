# Contact email REQUIRED by SEC and recommended by NCBI for User-Agent identification.
MEDFUEL_CONTACT_EMAIL=contact@example.com
MEDFUEL_USER_AGENT="MedFuel/0.1 (contact@example.com)"

# Database URL. Defaults to local SQLite; swap to a Supabase/Postgres URL in production.
MEDFUEL_DATABASE_URL=sqlite:///./medfuel.sqlite

# Optional API keys. Adapters degrade gracefully when absent.
MEDFUEL_OPENFDA_API_KEY=
MEDFUEL_NCBI_API_KEY=
MEDFUEL_USPTO_API_KEY=
MEDFUEL_FIRECRAWL_API_KEY=

# Firecrawl base URL (override for self-hosted deployments).
MEDFUEL_FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# LLM routing. Off by default; the deterministic stubs cover extraction
# (rule-based) and narrative generation (templated) without external SDKs.
MEDFUEL_USE_LLM=0
MEDFUEL_OPENAI_API_KEY=
MEDFUEL_ANTHROPIC_API_KEY=
# `gpt-5.4-mini` per current public OpenAI docs. Override to an internal
# alias (for example "gpt-5.5-mini") via env if your deployment exposes one.
MEDFUEL_EXTRACTION_MODEL=gpt-5.4-mini
MEDFUEL_EXTRACTION_ADJUDICATOR_MODEL=gpt-5.5
MEDFUEL_NARRATIVE_MODEL=claude-opus-4-7
MEDFUEL_NARRATIVE_FALLBACK_MODEL=claude-sonnet-4-6
